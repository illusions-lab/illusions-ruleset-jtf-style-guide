{
  "name": "illusions-ruleset-jtf-style-guide",
  "version": "0.2.1",
  "private": false,
  "description": "illusions 校正ルールセット — JTF日本語標準スタイルガイド（日本翻訳連盟）",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup",
    "build:min": "tsup --minify",
    "validate": "node scripts/validate.mjs",
    "check": "npm run validate && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
