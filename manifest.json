      }
    },
    {
      "ruleId": "jtf-1-2-1-punctuation",
      "nameJa": "全角の読点・句点を使う",
      "descriptionJa": "句読点には全角の「、」と「。」を使います。和文の句読点としてピリオド（.）とカンマ（,）は使用しません。",
      "guidelineId": "jtf-style-guide",
      "level": "L1",
      "defaultConfig": {
        "enabled": true,
        "severity": "warning"
